# Stripe MCP Server - Environment Variables (copy to .env)
# Get your keys from: https://dashboard.stripe.com/apikeys

# Required: Stripe secret key (starts with sk_)
# Test mode: sk_test_...
# Live mode:  sk_live_...
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here

# Optional: Webhook signing secret (premium feature)
# Get this from Stripe Dashboard → Developers → Webhooks → your endpoint
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=

# Optional: Server configuration
PORT=3100

# Optional: Transport mode override (set "http" for SSE-based HTTP server)
# Default is "stdio" — compatible with Claude Desktop and most MCP clients
# Use "http" for remote access or when stdio is not available
# TRANSPORT=stdio
